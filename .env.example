# Copie este arquivo para .env e preencha os valores.
# NUNCA commite o arquivo .env real no GitHub.

SECRET_KEY=qualquer-string-longa-aleatoria-minimo-32-caracteres
JWT_SECRET_KEY=outra-string-longa-diferente-da-de-cima

POSTGRES_DB=radar
POSTGRES_USER=radar
POSTGRES_PASSWORD=radar_secret

REDIS_PASSWORD=redis_secret

OPENAI_API_KEY=sk-sua-chave-aqui

DATABASE_URL=postgresql+asyncpg://radar:radar_secret@postgres:5432/radar
REDIS_URL=redis://:redis_secret@redis:6379/0

# Usado pelo frontend (Next.js) para chamar a API
NEXT_PUBLIC_API_URL=http://localhost:8000
